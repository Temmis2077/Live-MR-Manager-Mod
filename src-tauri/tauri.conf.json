{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Live MR Manager(Beta)",
  "version": "0.4.10",
  "identifier": "com.autumncolor77.live-mr-manager",
  "build": {
    "frontendDist": "../src",
    "devUrl": "http://localhost:1420",
    "beforeDevCommand": "npm run dev"
  },
  "app": {
    "withGlobalTauri": true,
    "windows": [
      {
        "title": "Live MR Manager(Beta) v0.4.10",
        "width": 1319,
        "height": 787,
        "minWidth": 1024,
        "minHeight": 600,
        "resizable": true,
        "decorations": false,
        "acceptFirstMouse": true
      }
    ],
    "security": {
      "csp": null,
      "assetProtocol": {
        "scope": [
          "$APPDATA/**",
          "$LOCALAPPDATA/**",
          "**"
        ]
      }
    }
  },
  "plugins": {
    "deep-link": {
      "desktop": {
        "schemes": ["live-mr-manager"]
      }
    }
  },
  "bundle": {
    "active": true,
    "targets": ["nsis"],
    "resources": [],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.ico"
    ]
  }
}
