# Meloming OAuth
# - CLIENT_ID: 로컬 .env 또는 GitHub Actions secret(MELOMING_CLIENT_ID)로 빌드에 임베드
# - CLIENT_SECRET: 배포 바이너리에 넣지 말 것. Vercel Companion env에만 설정
# - 로컬에서 Secret 없이 테스트하려면 Companion 교환을 켜고 Vercel에 Secret을 둘 것
MELOMING_CLIENT_ID=
MELOMING_CLIENT_SECRET=
MELOMING_API_KEY=
# 미설정 시: 로컬 Secret이 없으면 Companion(/api/oauth/exchange·refresh) 자동 사용
# true/false로 강제 가능
MELOMING_USE_COMPANION_EXCHANGE=
